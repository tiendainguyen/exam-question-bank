# Copy to .env (gitignored) and fill in. These are the ONLY keys this app reads.

# --- Database (Postgres / Supabase pooler) ---
# Supabase pooler requires the project ref in the username: postgres.<project-ref>
DB_URL=jdbc:postgresql://localhost:5432/exambank
DB_USER=exambank
DB_PASSWORD=exambank

# --- Auth (JWT) ---
APP_JWT_SECRET=change-me-min-32-bytes-long-secret-0123456789
# APP_JWT_ACCESS_TTL=PT15M

# --- AI extraction (OpenAI-compatible; default = Groq free tier) ---
# Only needed when using the "AI" extraction method. Get a free key at console.groq.com
AI_API_KEY=
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

# --- Storage ---
# EXAM_STORAGE_DIR=./data/exams
